/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/

# 构建产物
/build
/dist
/dist-ssr
/coverage

# 运行期生成物
/public/covers/
/public/summaries/
/public/*.md

# 杂项
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# 调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# 缓存
/.turbo/
/.cache/
